/* =========================================================
   QUBE CUSTOM PRESTIGE THEME (v1.1 - SLATE LIGHT MODE)
   ========================================================= */

/* --- GLOBAL FONT ENFORCEMENT (must match base.qss: toggling theme replaces the whole sheet) --- */
.ToolsPaneHeader,
.SettingsHeader {
    font-weight: 600;
}

.ToolsPaneControl,
.ToolsPaneInput,
QLabel,
QPushButton {
    font-weight: 400;
}

/* --- GLOBAL TOOLTIP --- */
QToolTip {
    background-color: #ffffff;
    color: #1e293b;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 11px;
    font-weight: normal;
    max-width: 300px;
}

/* --- 1. GLOBAL SHELL (The Canvas vs. The Surface) --- */
#MainContainer {
    background-color: #f1f5f9; 
    border: 1px solid #cbd5e1;
    border-radius: 12px;
}

#TopBar {
    background-color: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
}

#NavSidebar { 
    background-color: #f8fafc; 
    border-right: 1px solid #e2e8f0; 
    border-bottom-left-radius: 12px; 
}

#HistorySidebar, #LibrarySidebar, #ModelManagerSidebar { 
    background-color: #f8fafc; 
    border-right: 1px solid #e2e8f0; 
}

#ToolsPane { 
    background-color: #f8fafc; 
    border-left: 1px solid #e2e8f0; 
}

#LibraryPreviewStage, #ChatStage, #SettingsScrollArea {
    background-color: #ffffff;
}

/* --- 2. TYPOGRAPHY (High Contrast) --- */
* {
    font-family: "Inter";
    color: #1e293b; /* Deep slate, almost black, but softer on the eyes */
}

#ViewTitle {
    font-size: 22px;
    font-weight: 800;
    color: #0f172a;
}

.SidebarTitle, .ToolsPaneHeader, .SectionHeaderLabel {
    font-weight: 800; 
    font-size: 10px; 
    letter-spacing: 1.2px; 
    color: #64748b; 
    text-transform: uppercase;
}

.MiniTelemetryText, .MiniLatencyLabel, .PreviewStatsText {
    color: #64748b;
    font-size: 10px;
}

#SettingsFormContainer QLabel {
    color: #475569; /* Slate 600 - Muted but readable */
    font-size: 13px;
    font-weight: bold;
}

/* --- 3. INPUTS & TEXT AREAS --- */
QLineEdit, QTextEdit, #DocumentPreviewArea {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    padding: 8px 12px;
    selection-background-color: #e2e8f0;
}

QLineEdit:focus, QTextEdit:focus {
    border: 1px solid #94a3b8;
    background-color: #ffffff;
}

/* --- 4. BUTTONS --- */
QPushButton {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 8px 12px;
    font-weight: bold;
    color: #1e293b;
}

QPushButton:hover { background-color: #f1f5f9; }
QPushButton:pressed { background-color: #e2e8f0; }

.PrimaryActionButton {
    background-color: #0f172a; 
    color: #ffffff; 
    border: none;
    border-radius: 6px;
}
.PrimaryActionButton:hover { background-color: #334155; }

.WindowControlButton, .IconButton, .NavButton {
    background-color: transparent; border: none;
}
.WindowControlButton:hover, .IconButton:hover, .NavButton:hover {
    background-color: #e2e8f0;
}
.NavButton:checked {
    background-color: #e2e8f0;
    font-weight: bold;
}

/* --- 5. LISTS --- */
QListWidget { background: transparent; border: none; outline: none; }
QListWidget::item { padding: 10px 12px; border-radius: 6px; margin-bottom: 4px; }
QListWidget::item:hover { background-color: #f1f5f9; }
QListWidget::item:selected {
    background-color: #e2e8f0;
    color: #0f172a;
    font-weight: bold;
}

/* --- 6. FORM CONTROLS (Remaining QComboBoxes & Spinners) --- */
QComboBox {
    combobox-popup: 1;
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 6px 12px;
    color: #1e293b;
}

QComboBox QFrame {
    background-color: #ffffff !important;
    border: 1px solid #cbd5e1 !important;
    border-radius: 6px;
}

QComboBox QAbstractItemView {
    background-color: #ffffff !important;
    color: #1e293b !important;
    border: none;
    outline: none;
    selection-background-color: #f1f5f9;
    selection-color: #0f172a;
}

QComboBox QAbstractItemView::item {
    min-height: 32px;
    padding: 4px 12px;
    color: #1e293b;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #f1f5f9;
    color: #0f172a;
}

/* Model Manager GGUF file combo — matches Settings form fields (white fill, #cbd5e1 border, 8px). */
#HubFileComboBox {
    combobox-popup: 1;
    background-color: #ffffff;
    color: #1e293b;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 13px;
    min-height: 22px;
}
#HubFileComboBox:hover,
#HubFileComboBox:focus {
    border: 1px solid #94a3b8;
}
#HubFileComboBox QFrame {
    background-color: #ffffff !important;
    border: 1px solid #cbd5e1 !important;
    border-radius: 8px;
}
#HubFileComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 28px;
    border: none;
    border-left: 1px solid #cbd5e1;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    background: transparent;
}
/* Hub combo chevron: set via ModelManagerView._apply_hub_combo_chevron (SVG + QUrl). */
/* Popup list: view() is reparented — Prestige-style list (matches toolbar menus). */
#HubFileComboDropdownView {
    background-color: #ffffff;
    color: #1e293b;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    outline: none;
    selection-background-color: #f1f5f9;
    selection-color: #0f172a;
}
#HubFileComboDropdownView::item {
    min-height: 32px;
    padding: 8px 12px;
    color: #1e293b;
    border-radius: 4px;
}
#HubFileComboDropdownView::item:selected {
    background-color: #f1f5f9;
    color: #0f172a;
}
#HubFileComboDropdownView::item:hover {
    background-color: #f1f5f9;
    color: #0f172a;
}
#HubFileComboDropdownView QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 6px;
    margin: 0px;
}
#HubFileComboDropdownView QScrollBar::handle:vertical {
    background: #cbd5e1;
    border-radius: 3px;
    min-height: 20px;
}
#HubFileComboDropdownView QScrollBar::add-line:vertical,
#HubFileComboDropdownView QScrollBar::sub-line:vertical {
    height: 0px;
}

QSpinBox::up-button, QDoubleSpinBox::up-button,
QSpinBox::down-button, QDoubleSpinBox::down-button {
    width: 0px; border: none;
}

/* --- 7. SCROLLBARS (MODERN LIGHT) --- */

/* Vertical Scrollbar */
QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 10px;
    margin: 0px;
}
QScrollBar::handle:vertical {
    background-color: #cbd5e1; /* Slate 300 */
    border-radius: 5px;
    min-height: 30px;
}
QScrollBar::handle:vertical:hover {
    background-color: #94a3b8; /* Slate 400 */
}

/* Horizontal Scrollbar */
QScrollBar:horizontal {
    border: none;
    background: transparent;
    height: 10px;
    margin: 0px;
}
QScrollBar::handle:horizontal {
    background-color: #cbd5e1;
    border-radius: 5px;
    min-width: 30px;
}
QScrollBar::handle:horizontal:hover {
    background-color: #94a3b8;
}

/* KILL THE WINDOWS 95 ARROWS */
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical,
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    border: none;
    background: none;
    width: 0px;
    height: 0px;
}

/* KILL THE CHUNKY TRACK BACKGROUND */
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical,
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: transparent;
}

/* Fix the tiny corner square where two scrollbars meet */
QAbstractScrollArea::corner {
    background: transparent;
}

/* --- 8. TELEMETRY CARDS --- */
#HardwareCard, #LatencyCard {
    background-color: #E9EFF5;
    border: 1px solid #dbe4ee;
    border-radius: 12px;
}

.LiveMetricText {
    font-family: 'Consolas', monospace;
    font-weight: bold;
    font-size: 11px;
    margin-left: 10px;
    color: #64748b;
}

.MetricTitle { font-weight: bold; font-size: 14px; color: #1e293b; }
.MetricSubtext { font-size: 11px; color: #64748b; }

.MetricValueLarge {
    font-size: 20px;
    font-weight: bold;
    font-family: 'Consolas', monospace;
    color: #0f172a;
}

/* --- MODEL MANAGER CHIP/BADGE LANGUAGE --- */
.MetaPanelCard, .DownloadOptionsCard {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
}

.MetaLabel {
    color: #64748b;
    font-size: 11px;
    font-weight: 600;
}

QLabel[class~="Chip"] {
    border-radius: 10px;
    padding: 4px 8px;
    border: 1px solid #cbd5e1;
    background: #f8fafc;
    color: #1e293b;
    font-size: 11px;
    font-weight: 600;
}

QLabel[class~="accent"] {
    background: #ede9fe;
    border: 1px solid #a78bfa;
    color: #1e3a8a;
}

QLabel[class~="primary"] {
    background: #dbeafe;
    border: 1px solid #93c5fd;
    color: #1e3a8a;
}

QLabel[class~="outlined"] {
    background: transparent;
    border: 1px solid #cbd5e1;
    color: #475569;
}

QLabel[class~="muted"] {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    color: #64748b;
}

QFrame[class~="capability"] {
    border-radius: 10px;
    padding: 0px;
    border: 1px solid #cbd5e1;
    background: #f8fafc;
}

QFrame[class~="capability"] QLabel[class="ChipLabel"],
QFrame[class~="capability"] QLabel[class="ChipIcon"] {
    color: #1e293b;
    background: transparent;
    border: none;
    padding: 0px;
}

/* Metadata card: keep one consistent blue stroke across all chips/badges. */
QFrame[class~="MetaPanelCard"] QLabel[class~="Chip"] {
    border: 1px solid #93c5fd;
}
QFrame[class~="MetaPanelCard"] QFrame[class~="capability"] {
    border: 1px solid #93c5fd;
}

/* Model Manager metadata capabilities: keep label text accent-blue in light mode. */
#ModelManagerMetaCard QFrame[class~="capability"] QLabel[class="ChipLabel"],
#ModelManagerMetaCard QFrame[class~="capability"] QLabel[class="ChipIcon"] {
    color: #1e3a8a;
}

/* --- 9. STATUS BUBBLE --- */
#StatusBubble {
    font-weight: bold; 
    border-radius: 13px; 
    font-size: 10px; 
    letter-spacing: 1.5px;
    padding: 4px 12px;
    border: none;
}

#StatusBubble[state="recording"] { 
    color: #ef4444; 
    background-color: rgba(239, 68, 68, 0.1); 
}

#StatusBubble[state="thinking"] { 
    color: #f59e0b; 
    background-color: rgba(245, 158, 11, 0.1); 
}

#StatusBubble[state="speaking"] {
    color: #f59e0b;
    background-color: rgba(245, 158, 11, 0.1);
}

#StatusBubble[state="idle"] { 
    color: #10b981; 
    background-color: rgba(16, 185, 129, 0.1); 
}

#StatusBubble[state="needs_model"] {
    color: #ea580c;
    background-color: rgba(234, 88, 12, 0.1);
}

/* --- 10. LIBRARY SPECIFIC --- */
#LibrarySearchBar, #HubModelSearchBar {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 8px 12px;
    margin-bottom: 5px;
}
#LibrarySearchBar:focus, #HubModelSearchBar:focus {
    border: 1px solid #94a3b8;
}

/* --- 11. PRESTIGE MENUS (Settings Triggers) --- */
/* The buttons themselves (The popup styling is now handled in Python) */
#SettingsMenuButton {
    text-align: left;
    padding: 8px 15px;
    background-color: #ffffff !important;
    border: 1px solid #cbd5e1 !important;
    color: #1e293b !important;
    border-radius: 6px;
}

#SettingsMenuButton:disabled {
    background-color: #f1f5f9 !important;
    border: 1px solid #e2e8f0 !important;
    color: #94a3b8 !important;
}
/* --- CHAT BUBBLES --- */
#ChatTranscriptContainer {
    background-color: transparent;
}

/* Explicitly target the QFrame to guarantee background painting */
#UserBubble {
    background-color: #0f172a; /* Slate Black */
    border-radius: 18px; 
}

#UserBubble QLabel {
    color: #ffffff; 
    background-color: transparent;
}

/* Explicitly target the Agent text to guarantee it stays readable */
QLabel#AgentHeader {
    color: #3b82f6; /* Bright blue for the QUBE header */
    font-weight: bold;
    font-size: 11px;
    letter-spacing: 1px;
    margin-top: 15px;
}

QLabel#AgentMessage {
    color: #1e293b; /* Dark slate text for high legibility on white */
    font-size: 14px;
    line-height: 1.5;
    background-color: transparent;
}
/* --- UNIFIED LIST STYLING (LIGHT) --- */
/* Conversations + Library sidebar lists only (Model Hub unchanged). */
#HistoryList, #LibraryDocList {
    background-color: #E9EFF5;
    border: none;
}

/* Match base.qss: no extra item padding — row widget supplies horizontal inset. */
#HistoryList::item, #LibraryDocList::item {
    padding: 0px;
    border-radius: 6px;
    margin-bottom: 4px;
}

#ModelHubList {
    background-color: transparent;
    border: none;
}

#HistoryList::item:hover, #LibraryDocList::item:hover, #ModelHubList::item:hover {
    background-color: rgba(0, 0, 0, 0.03);
}

#HistoryList::item:selected, #LibraryDocList::item:selected, #ModelHubList::item:selected {
    background-color: rgba(0, 0, 0, 0.03);
    border: 1px solid #8b5cf6;
    border-radius: 6px;
}

/* Hub list: item widgets size themselves; global QListWidget::item padding would shrink rows and clip 3-line text */
#ModelHubList::item {
    padding: 0px;
    border-radius: 6px;
    margin-bottom: 4px;
    background-color: #E9EFF5;
}

/* Do not inherit QListWidget::item:selected font-weight — conflicts with fixed QFontMetrics row height */
#ModelHubList::item:selected {
    font-weight: 500;
}

/* Sidebar row titles: scope to QListWidget::item (setItemWidget); light = slate always */
#HistoryList::item QLabel#HistoryRowTitle,
#LibraryDocList::item QLabel#HistoryRowTitle,
#LibraryDocList::item QLabel#LibraryRowTitle {
    background-color: transparent !important;
    font-size: 13px;
    font-weight: 500;
    color: #1e293b !important;
}

/* Model Manager hub rows: same font metrics as base.qss (size, weight). No line-height — matches QFontMetrics sizing. */
#ModelHubList QLabel#HubModelRowTitle {
    font-size: 13px;
    font-weight: 500;
    color: #1e293b !important;
    background-color: transparent;
    border: none;
    padding: 0px;
    margin: 0px;
}

#ModelHubList::item:selected QLabel#HubModelRowTitle {
    color: #1e293b !important;
}

#HistoryOptionsBtn, #LibraryOptionsBtn {
    background: transparent;
    border: none;
    padding: 0px;
    min-width: 0px;
    min-height: 0px;
}

#HistoryOptionsBtn:hover, #LibraryOptionsBtn:hover {
    background-color: rgba(0, 0, 0, 0.05);
    border-radius: 4px;
}

/* --- LIBRARY PREVIEW HEADER --- */
#PreviewDocTitle {
    font-size: 22px;
    font-weight: bold;
    color: #1e293b; /* Deep slate */
    letter-spacing: 1px;
}

#PreviewStatsText {
    font-size: 13px;
    color: #64748b; /* Lighter slate metadata */
    font-weight: 500;
}

/* --- INGEST PROGRESS BAR --- */
#IngestProgressBar {
    background-color: #e2e8f0;
    border: none;
    border-radius: 2px;
}
#IngestProgressBar::chunk {
    background-color: #3b82f6; /* Bright blue loading bar */
    border-radius: 2px;
}