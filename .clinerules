│   └── screenshots/        # Screenshots of the app for Github
├── ui/                     # Presentation Layer (Dumb Components)
│   ├── main_window.py      # Frameless window, sidebar, stacked views, global right toolbar (LOCAL LLM dropdown, voice, params), Prestige QMenu builders, theme toggle; passes native_engine into TelemetryView for capability telemetry.
│   ├── components/         # Reusable custom UI components.
